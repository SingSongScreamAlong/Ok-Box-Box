# Ok, Box Box Relay Agent Configuration

# API endpoint - use production URL for live racing
# Local: http://localhost:4000
# Production: https://octopus-app-qsi3i.ondigitalocean.app
API_ENDPOINT=https://octopus-app-qsi3i.ondigitalocean.app

# Relay token (set by launcher after license validation)
RELAY_TOKEN=

# Logging
LOG_LEVEL=INFO

# Telemetry rate (Hz)
TELEMETRY_RATE=30

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL=5

# Video streaming (iRacing window capture)
VIDEO_ENABLED=true
VIDEO_FPS=60
VIDEO_QUALITY=85
VIDEO_SCALE=0.75
