# =====================================================================
# Ok Box Box — Web App Environment Variables
# Copy to .env and fill in your values
# =====================================================================

# ─── Supabase (user auth) ───
# Get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── API Server URL ───
# Local dev: http://localhost:3001
# Production: https://app.okboxbox.com (or your deployed API URL)
VITE_API_URL=http://localhost:3001

# ─── WebSocket URL (optional — defaults to VITE_API_URL) ───
# VITE_WS_URL=ws://localhost:3001

# ─── Relay Mock Mode ───
# Set to 'true' to simulate relay connection with fake telemetry
VITE_RELAY_MOCK=false
