# =====================================================================
# Ok Box Box — Server Environment Variables
# Copy to .env and fill in your values
# =====================================================================

# ─── Runtime ───
NODE_ENV=development
PORT=3001

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql://controlbox:controlbox_dev@localhost:5432/controlbox

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ───
# In production: set a strong 64+ char secret
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ─── Supabase (user auth) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── CORS (comma-separated origins) ───
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,https://app.okboxbox.com

# ─── OpenAI (for IDP debrief + AI features) ───
OPENAI_API_KEY=sk-...

# ─── ElevenLabs (optional — voice synthesis) ───
ELEVENLABS_API_KEY=

# ─── DigitalOcean Spaces (clip + artifact cloud storage) ───
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=controlbox-artifacts
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3

# ─── iRacing OAuth (optional — iRacing account linking) ───
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=
IRACING_TOKEN_ENCRYPTION_KEY=

# ─── Stripe Billing (optional — not needed for FP1) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DRIVER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_LEAGUE=

# ─── Admin Seeding ───
SEED_ADMIN_EMAIL=admin@okboxbox.com
SEED_ADMIN_PASSWORD=

# ─── FP1 Testing ───
# Grants all driver capabilities to free tier users
FP1_TESTING_MODE=true

# ─── Observability (optional) ───
METRICS_ENABLED=false
DIAGNOSTICS_ENABLED=false
OPS_UI_ENABLED=0
ALLOW_ANONYMOUS_SOCKET_VIEWERS=false
