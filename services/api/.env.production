# Production Environment - Set these in Digital Ocean App Platform
PORT=4000
NODE_ENV=production

# Database - Set via DO Managed Database connection string
DATABASE_URL=

# JWT Secret - Generate a strong random string
JWT_SECRET=

# CORS - Allowed origins for the frontend
CORS_ORIGIN=https://blackbox.okboxbox.com,https://okboxbox.com

# Logging
LOG_LEVEL=info
