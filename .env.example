# Ok, Box Box Environment Configuration

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/controlbox
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=controlbox
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Server Configuration
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5175

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
ALLOW_ANONYMOUS_SOCKET_VIEWERS=false

# External Services
OPENAI_API_KEY=your-openai-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Squarespace Integration
SQUARESPACE_WEBHOOK_SECRET=your-squarespace-webhook-secret

# iRacing Configuration
IRACING_EMAIL=your-iracing-email
IRACING_PASSWORD=your-iracing-password

# Relay Agent — server URL the Windows relay connects to
# Override to point at a different server (e.g. local dev or staging)
BLACKBOX_SERVER_URL=https://your-server.example.com

# Admin Seeding — set before first deployment to avoid the predictable default
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-me-before-deploying
DEV_SEED_ADMIN_PASSWORD=optional-local-dev-password

# Development
LOG_LEVEL=INFO
POLL_RATE_HZ=10

# Trust System
CONFIDENCE_GATE_THRESHOLD=0.6

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id