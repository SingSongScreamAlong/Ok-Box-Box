# =====================================================================
# Ok Box Box — Relay Agent Environment Variables
# Copy to .env and fill in your values
# =====================================================================

# ─── Server URL ───
# Local dev: http://localhost:3001
# Production: https://api.okboxbox.com
SERVER_URL=https://api.okboxbox.com

# ─── Auth Token ───
# Get from: Ok Box Box App → Settings → Relay Token
AUTH_TOKEN=your_token_here

# ─── Telemetry ───
POLL_RATE_HZ=10
LOG_LEVEL=INFO
LOG_TELEMETRY=false

# ─── Screen Capture (Replay Intelligence) ───
# Set to false to disable clip recording
SCREEN_CAPTURE_ENABLED=true
